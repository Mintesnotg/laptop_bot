{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API + Bot (tsx)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"],
      "sourceMaps": true,
      "smartStep": true,
      "restart": true,
      "autoAttachChildProcesses": true
    },
    {
      "name": "Attach API + Bot (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"],
      "sourceMaps": true
    }
  ]
}
