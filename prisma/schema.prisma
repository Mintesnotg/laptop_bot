generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UsageTag {
  STUDENT
  OFFICE
  DESIGN
  GAMING
  CODING
  GRAPHICS_DESIGN
  ARCHITECTURE
  FINANCE
  MARKETING
  HR
  SALES
  ENGINEERING
  DEVOPS
  PRODUCT
  UX_UI
  ANALYTICS
  READING
  DAILY_BROWSING
}

enum StorageType {
  SSD
  NVME
  HDD
}

model TelegramUser {
  id                     Int                     @id @default(autoincrement())
  telegramUserId         BigInt                  @unique
  username               String?
  firstName              String?
  lastName               String?
  languageCode           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  preferences            UserPreference[]
  recommendationRequests RecommendationRequest[]
  activityLogs           UserActivityLog[]
}

model UserPreference {
  id        String       @id @default(cuid())
  userId    Int
  budgetMin Int
  budgetMax Int
  usageTag  UsageTag
  ramGb     Int
  storageGb Int
  createdAt DateTime     @default(now())
  user      TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Product {
  id                    String                 @id @default(cuid())
  brand                 String
  model                 String
  price                 Int
  ramGb                 Int
  storageGb             Int
  storageType           StorageType            @default(SSD)
  cpu                   String
  gpu                   String?
  usageTags             UsageTag[]
  description           String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  images                ProductImage[]
  recommendationResults RecommendationResult[]

  @@index([price])
  @@index([ramGb, storageGb])
  @@unique([brand, model])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model RecommendationRequest {
  id             String                 @id @default(cuid())
  telegramUserId Int?
  budgetMin      Int
  budgetMax      Int
  usageTag       UsageTag
  ramGb          Int
  storageGb      Int
  createdAt      DateTime               @default(now())
  user           TelegramUser?          @relation(fields: [telegramUserId], references: [id], onDelete: SetNull)
  results        RecommendationResult[]

  @@index([createdAt])
  @@index([usageTag, budgetMin, budgetMax])
}

model RecommendationResult {
  id        String                @id @default(cuid())
  requestId String
  productId String
  score     Float
  rank      Int
  request   RecommendationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@unique([requestId, productId])
}

model UserActivityLog {
  id        String        @id @default(cuid())
  userId    Int?
  action    String
  payload   Json?
  createdAt DateTime      @default(now())
  user      TelegramUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BudgetOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  min       Int
  max       Int
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model RamOption {
  id        String   @id @default(cuid())
  gb        Int      @unique
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model StorageOption {
  id        String   @id @default(cuid())
  gb        Int      @unique
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
