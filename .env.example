# App
NODE_ENV=development
API_PORT=3000
BOT_API_BASE_URL=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_API_ROOT=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
BOT_MODE=polling
BOT_WEBHOOK_PATH=/telegram/webhook
PUBLIC_WEBHOOK_URL=

# Enterprise TLS options
# Path to corporate root CA PEM used for SSL inspection
TELEGRAM_CA_CERT_PATH=
# Temporary local-only fallback (not recommended in production)
TELEGRAM_TLS_INSECURE=false

# Admin
ADMIN_API_KEY=change-me

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/laptop_bot?schema=public
